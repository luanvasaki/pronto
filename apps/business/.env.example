# URL do backend — precisa estar na lista CORS_ORIGINS do backend
# pra sessão via cookie funcionar. Em produção, usar "/api" em vez da
# URL do Railway — o rewrite (ver next.config.ts) faz o proxy same-
# origin, que evita o bloqueio de cookie cross-site do Safari/WebKit
# no iPhone. BACKEND_ORIGIN (sem NEXT_PUBLIC_, só server-side) precisa
# apontar pra URL real do backend nesse caso.
NEXT_PUBLIC_API_URL=http://localhost:4000
BACKEND_ORIGIN=

# Client ID do OAuth do Google (mesmo valor do backend GOOGLE_CLIENT_ID —
# client id não é secreto). Sem isso, o botão "Entrar com Google" não
# aparece.
NEXT_PUBLIC_GOOGLE_CLIENT_ID=

# DSN do projeto no Sentry (sentry.io) — opcional em qualquer ambiente.
# Sem isso, captura de erro no client vira no-op (ver src/lib/sentry.ts).
NEXT_PUBLIC_SENTRY_DSN=
