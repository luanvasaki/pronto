PORT=4000
NODE_ENV=development

# Postgres local (ver README para como provisionar)
DATABASE_URL=postgresql://shift:shift_dev_password@localhost:5433/shift_dev

# Segredo de assinatura do JWT — gerar um valor forte por ambiente,
# nunca reusar este placeholder em staging/produção.
JWT_SECRET=dev-only-change-me

# Origens autorizadas a mandar cookie de sessão (worker e business locais)
CORS_ORIGINS=http://localhost:3000,http://localhost:3200
