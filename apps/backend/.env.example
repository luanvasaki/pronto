PORT=4000
NODE_ENV=development

# Postgres local (ver README para como provisionar)
DATABASE_URL=postgresql://shift:shift_dev_password@localhost:5433/shift_dev

# Segredo de assinatura do JWT — gerar um valor forte por ambiente,
# nunca reusar este placeholder em staging/produção.
JWT_SECRET=dev-only-change-me

# Origens autorizadas a mandar cookie de sessão (worker e business locais)
CORS_ORIGINS=http://localhost:3000,http://localhost:3200

# Tokens do Vercel Blob — dois stores diferentes, um `public` (foto de
# perfil, logo da empresa) e um `private` (documento de KYC); o Blob
# rejeita gravar com access que não bate com o tipo do store, por isso
# não dá pra usar o mesmo token pros dois.
# (`vercel blob create-store <nome> --access public|private`, depois
# `vercel env pull` ou copie do dashboard). Opcionais: sem eles,
# createFileStorage() usa disco local (só o suficiente pra rodar os testes).
BLOB_READ_WRITE_TOKEN=
BLOB_DOCUMENTS_TOKEN=

# Resend (e-mail de redefinição de senha). Sem isso, createEmailSender()
# usa ConsoleEmailSender (loga o link) em dev — obrigatório em produção.
RESEND_API_KEY=
RESEND_FROM_EMAIL=

# Client ID do OAuth do Google (Google Cloud Console — não precisa de
# client secret, o fluxo usado só verifica o ID token). Obrigatório em
# produção pra createGoogleTokenVerifier() funcionar.
GOOGLE_CLIENT_ID=
