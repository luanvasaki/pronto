# URL do backend — precisa estar na lista CORS_ORIGINS do backend
# pra sessão via cookie funcionar.
NEXT_PUBLIC_API_URL=http://localhost:4000

# Client ID do OAuth do Google (mesmo valor do backend GOOGLE_CLIENT_ID —
# client id não é secreto). Sem isso, o botão "Entrar com Google" não
# aparece.
NEXT_PUBLIC_GOOGLE_CLIENT_ID=
